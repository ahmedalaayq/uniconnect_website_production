{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "uniconnect-c7571",
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "storage.rules",
      ".env",
      ".env.*",
      ".gitignore",
      "node_modules/**",
      ".kiro/**",
      "*.md",
      "CLAUDE.md",
      "ENABLE_AUTH.md",
      "FIREBASE_SETUP.md",
      "FIRESTORE_RULES.md",
      "QUICK_START.md",
      "TROUBLESHOOTING.md",
      "final-test.html",
      "package-lock.json"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/dashboard",
        "destination": "dashboard.html"
      },
      {
        "source": "/profile",
        "destination": "profile.html"
      },
      {
        "source": "/messages",
        "destination": "dm.html"
      },
      {
        "source": "/settings",
        "destination": "setting.html"
      },
      {
        "source": "/register",
        "destination": "login.html"
      }
    ]
  }
}
